# Mayhem target: the ACPI AML bytecode interpreter (acpi::aml::Interpreter::load_table), built by
# mayhem/build.sh via cargo-fuzz as a libFuzzer binary at /mayhem/fuzz_target_1. Target name
# `acpi` preserved from the old fork for Mayhem corpus/defect continuity.
project: savantenvs/acpi
target: acpi
testsuite:
  - https://$MAYHEM_DOMAIN/$MAYHEM_PROJECT/$MAYHEM_TARGET/testsuite.tar
  - file://mayhem/acpi/testsuite
cmds:
  - cmd: /mayhem/fuzz_target_1
    libfuzzer: true
